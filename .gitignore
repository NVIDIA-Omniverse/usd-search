_old/

# /quickstart skill output — saved thumbnails per query, not source
quickstart-results/

# /usd-property-catalog skill output — generated catalog + config stanzas, not source
# (anchored to root so skills/usd-property-catalog/ stays trackable)
/usd-property-catalog/

# nv-base skill validation reports (ci/skills/validate_skills.sh w/ SKILL_VALIDATION_OUT_DIR) — CI artifacts, not source
skill-validation-reports/

# Locally built wheels (generated by build/build_pytinyexr.sh — not committed)
wheels/*.whl

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
# The public Explorer image serves this tracked, pre-built bundle (regenerated
# by scripts/generate-explorer-build.sh); keep it under version control.
!services/explorer/dist/
!services/explorer/dist/**
**/build/
!/build/
.eggs/

# uv / venv
.venv/
uv.lock
# Tracked uv.lock files (workspace root + excluded services with their own lock).
# Used by scripts/generate_third_party_notice.sh; deps must stay reproducible.
!/uv.lock
!services/siglip2-triton/docker/uv.lock
!/ci/skills/uv.lock
!services/rendering-job/uv.lock
!services/asset-graph-builder/uv.lock

# Test / coverage
.coverage
coverage.xml
htmlcov/
.pytest_cache/
.mypy_cache/

# IDE
.idea/
.vscode/
*.swp

# Triton model weights are tracked via Git LFS (see .gitattributes)

# rendering-job shader caches (populated at runtime by Kit)
services/rendering-job/shadercache/
services/rendering-job/nv_shadercache/

.coverage.*
_tmp
test-sample.png

# Helm dependency downloads (fetched at package time, not committed)
helm/usdsearch/charts/*.tgz
# CI build artifacts
_charts/
_protos
# Generated by scripts/build-openapi-static-html.sh; produced by CI on default branch
docs/openapi.html

# Local S3 assets directory (user data for docker-compose.local-s3.yml)
local-assets/
!local-assets/.gitkeep

*.ipynb
*.tgz
search-results

# Benchmark run artifacts — per-experiment cache of agent responses
benchmark/_cache/
benchmark/RESULTS.md

# custom helm config
my-usdsearch-config.yaml

# Dev-only CRA proxy — contains local creds, must never be committed
services/explorer/src/setupProxy.js
skill-validation
THIRD_PARTY_NOTICE_DIFF.md
validation-reports
