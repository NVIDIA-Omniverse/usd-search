name: "siglip2_text_encoder_onnx"
backend: "onnxruntime"
max_batch_size: 32

input [
  {
    name: "input_ids"
    data_type: TYPE_INT64
    dims: [64]
  }
]

output [
  {
    name: "embeddings"
    data_type: TYPE_FP32
    dims: [1536]
  }
]

dynamic_batching {
  preferred_batch_size: [8, 16, 32]
  max_queue_delay_microseconds: 50000
}

instance_group [
  {
    count: 2
    kind: KIND_AUTO
  }
]

parameters {
  key: "execution_accelerators"
  value: { string_value: "cuda:0" }
}
parameters {
  key: "enable_mem_pattern"
  value: { string_value: "1" }
}
parameters {
  key: "enable_mem_reuse"
  value: { string_value: "1" }
}

optimization {
  graph {
    level: 0
  }
}

model_warmup [
  {
    name: "warmup_batch_1"
    batch_size: 1
    inputs [
      {
        key: "input_ids"
        value: {
          data_type: TYPE_INT64
          dims: [64]
          zero_data: true
        }
      }
    ]
  }
]
